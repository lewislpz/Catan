{
  "name": "@hexaforge/game-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts --clean",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push"
  },
  "dependencies": {
    "@colyseus/core": "^0.15.57",
    "@hexaforge/game-engine": "workspace:*",
    "@hexaforge/shared": "workspace:*",
    "@colyseus/schema": "^2.0.37",
    "@colyseus/ws-transport": "^0.15.0",
    "@prisma/client": "^6.4.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "nanoid": "^5.1.5"
  },
  "devDependencies": {
    "colyseus.js": "^0.16.22",
    "prisma": "^6.4.1"
  }
}
